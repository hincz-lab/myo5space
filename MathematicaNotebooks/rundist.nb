Cell[TextData[{
 "Both the hypergeometric functions are of the special form, \
Hypergeometric2F1[a, 1/2+a, 2a, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "]"}], "=", 
    FractionBox[
     SuperscriptBox["2", 
      RowBox[{
       RowBox[{"2", "a"}], "-", "1"}]], 
     RowBox[{
      SqrtBox[
       RowBox[{"1", "-", "x"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SqrtBox[
          RowBox[{"1", "-", "x"}]]}], ")"}], 
       RowBox[{
        RowBox[{"2", "a"}], "-", "1"}]]}]]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9d812368-2e9c-42c8-8d11-cb633309e537"],
 ", (from Abramowitz and Stegun, eq 15.1.14). This relationship is not \
encoded in Mathematica."
}], "Text",
 CellChangeTimes->{{3.8013968091653748`*^9, 3.8013969014838457`*^9}, {
  3.8013971317467203`*^9, 3.8013972809330463`*^9}, {3.801397490273611*^9, 
  3.8013975070240307`*^9}, {3.8013980875459223`*^9, 
  3.801398089546582*^9}},ExpressionUUID->"1f37aca3-484c-4fd1-8b6b-\
e91ff517ed8d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Function", " ", "to", " ", "replace", " ", "the", " ", "hypergeometric", 
    " ", "functions", " ", 
    RowBox[{"with", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"hypGeo2F1Rep", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "a"}], "-", "1"}], ")"}]}], 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", "x"}], "]"}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "-", "x"}], "]"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "a"}], "-", "1"}], ")"}]}]}]], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "\[Rule]", 
        FractionBox[
         RowBox[{"2", "+", "z"}], "2"]}], ",", 
       RowBox[{"x", "\[Rule]", 
        FractionBox[
         RowBox[{"4", " ", "pB", " ", "pF"}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "pLs", "+", "pTs"}], ")"}], "2"]]}]}], 
      "}"}]}], "//", "Simplify"}]}]}]], "Input",
 CellChangeTimes->{{3.801397975848876*^9, 3.801398234045741*^9}, {
  3.801398711582271*^9, 3.801398727165208*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"401933b3-789b-4a5a-98c3-838e118650f9"],

