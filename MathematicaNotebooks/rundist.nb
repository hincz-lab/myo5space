Cell["Author: Joshua Holmes (jbh92@case.edu)", "Text",
 CellChangeTimes->{{3.801422334091131*^9, 3.801422341991465*^9}, {
  3.8560769330460253`*^9, 
  3.856076936637636*^9}},ExpressionUUID->"40f4ed82-bf4e-4877-8688-\
530fb6ceeeec"],

Cell["\<\
We derive an expressions for the distribution of run distances a myosin motor \
takes along actin. The following notation is used.
pLs: The probability of a leading stomp.
pTs: The probability of a trailing stomp.
pB: The probability of a backward step.
pF: The probability of a forward step.
pT: The probability of terminating.
i: The number of forward steps during a trajectory.
j: The number of backwards steps during a trajectory.
k: The combined number of leading and trailing stomps during a trajectory.\
\>", "Text",
 CellChangeTimes->{{3.801395533018749*^9, 
  3.801395731849927*^9}},ExpressionUUID->"acb0f5d3-b4c5-40e3-b4fb-\
4336b8cff913"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Time", " ", "independent", " ", "probability", " ", "of", " ", "a", " ", 
    "given", " ", "displacement", " ", "trajectory", " ", "along", " ", 
    RowBox[{"actin", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"pDispTraj", "=", 
   RowBox[{
    RowBox[{"Multinomial", "[", 
     RowBox[{"i", ",", "j", ",", "k"}], "]"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"pLs", "+", "pTs"}], ")"}], "^", "k"}], " ", 
    RowBox[{"pF", "^", "i"}], " ", 
    RowBox[{"pB", "^", "j"}], " ", "pT"}]}]}]], "Input",
 CellChangeTimes->{{3.801390516322311*^9, 3.801390660917121*^9}, {
  3.80139548513944*^9, 3.801395528325654*^9}, {3.801401402474864*^9, 
  3.8014014345748777`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"9dd3f1ca-00eb-4689-8c96-0c966d079882"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["pB", "j"], " ", 
  SuperscriptBox["pF", "i"], " ", "pT", " ", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"pLs", "+", "pTs"}], ")"}], "k"], " ", 
  RowBox[{"Multinomial", "[", 
   RowBox[{"i", ",", "j", ",", "k"}], "]"}]}]], "Output",
 CellChangeTimes->{3.8013955014597187`*^9, 3.8014015540931187`*^9, 
  3.801402922585812*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"21766604-0892-4dca-9a6e-06afed7adaa4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "Probability", " ", "of", " ", "a", " ", "net", " ", "displacement", " ",
       "z"}], "=", 
     RowBox[{"i", "-", "j"}]}], ",", " ", 
    RowBox[{"z", ">", "0"}], ",", " ", 
    RowBox[{"at", " ", 
     RowBox[{"termination", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"pZPos1", "=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"pDispTraj", " ", 
        RowBox[{"KroneckerDelta", "[", 
         RowBox[{"z", "+", "i", "-", "j"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], ";"}], 
   " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pZPos2", "=", 
     RowBox[{"Sum", "[", 
      RowBox[{"pZPos1", ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pZPos3", "=", 
     RowBox[{"Sum", "[", 
      RowBox[{"pZPos2", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"pZPos", "=", 
    RowBox[{
     RowBox[{"Refine", "[", 
      RowBox[{"pZPos3", ",", 
       RowBox[{"z", ">", "0"}]}], "]"}], "//", 
     "FullSimplify"}]}]}]}]], "Input",
 CellChangeTimes->{{3.8013957502606697`*^9, 3.801395918832569*^9}, {
  3.80139602414246*^9, 3.8013960312669773`*^9}, {3.801396170979576*^9, 
