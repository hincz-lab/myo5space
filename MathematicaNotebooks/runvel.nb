Cell[CellGroupData[{

Cell["The general average run velocity", "Subsection",
 CellChangeTimes->{{3.801406059749845*^9, 
  3.8014060687999*^9}},ExpressionUUID->"d99d1674-993d-415f-8afa-6637bfeb5fbd"],

Cell[TextData[{
 "The average run velocity has the general form,  \[LeftAngleBracket]v\
\[RightAngleBracket]=",
 Cell[BoxData[
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"z", "=", "0"}], "\[Infinity]"], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
    RowBox[{
     FractionBox["z", "t"], "f", 
     RowBox[{"(", 
      RowBox[{"z", ",", "t"}], ")"}], 
     RowBox[{"\[DifferentialD]", "t"}]}]}]}]],ExpressionUUID->
  "b1b83e21-34ff-4fd5-90d7-5780daa36a47"],
 " . Mathematica does not handle some of the intermediate calculations well \
so they are laid out here first.\n \
\[LeftAngleBracket]v\[RightAngleBracket]=",
 Cell[BoxData[
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"z", "=", "0"}], "\[Infinity]"], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
    RowBox[{
     FractionBox["z", "t"], "f", 
     RowBox[{"(", 
      RowBox[{"z", ",", "t"}], ")"}], 
     RowBox[{"\[DifferentialD]", "t"}]}]}]}]],ExpressionUUID->
