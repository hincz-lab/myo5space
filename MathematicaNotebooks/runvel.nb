bea1dae3fe88"],

Cell[TextData[{
 "The following derivations assume that in the case of the fastest motor, \
there would be no backward stepping, i.e. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["k", "d2"], "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "c65b7acf-251d-4492-b904-9869794a6817"],
 ". This assumption makes it possible to simplify the average run velocity \
expression. Note that the probabilities represent different quantities than \
before."
}], "Text",
 CellChangeTimes->{{3.801420369871234*^9, 
  3.80142049879419*^9}},ExpressionUUID->"db8df956-1205-467a-a796-\
fd8dccd70bbc"],

